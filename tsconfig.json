{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2020",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "lib": [
      "DOM",
      "ES2020"
    ],
    "types": [
      "node",
      "obsidian"
    ],
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "version-bump.mjs"
  ]
}

